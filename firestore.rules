rules_version = '2';

// Firestore Security Rules for Devdutt Sharma's portfolio (project: zynexalpha)
//
// Everyone can READ site content (bio, projects, skills, etc.) — that's the
// whole point of a portfolio. Only the signed-in admin account can WRITE.
//
// Deploy this from the Firebase Console:
//   Firestore Database -> Rules -> paste this in -> Publish
// or with the Firebase CLI:
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "devdutt0817@gmail.com"
        && request.auth.token.email_verified == true;
    }

    // Home hero text, bio, skills list stored as single docs under "site"
    match /site/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin-added projects (in addition to the 3 static ones on the page)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Planned / future projects roadmap
    match /futureProjects/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Skill tags
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
